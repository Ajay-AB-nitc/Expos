//idle process 
loadi(72,11);
loadi(73,12);

//loading module 7 (boot module)
loadi(54, 67);
loadi(55, 68);

//setting sp to kernel stack of idle process as boot module uses this stack
SP = 74 * 512 - 1;


call BOOT_MODULE;




//idle process page table/////////
PTLR = 10;
PTBR = PAGE_TABLE_BASE;

//library
[PTBR+0] = 63;
[PTBR+1] = "0100";
[PTBR+2] = 64;
[PTBR+3] = "0100";

//heap
[PTBR+4] = -1;
[PTBR+5] = "0000";
[PTBR+6] = -1;
[PTBR+7] = "0000";

//Code
[PTBR+8] = 72;
[PTBR+9] = "0100";
[PTBR+10] = 73;
[PTBR+11] = "0100";
[PTBR+12] = -1;
[PTBR+13] = "0000";
[PTBR+14] = -1;
[PTBR+15] = "0000";

//stack
[PTBR+16] = 71;
[PTBR+17] = "0110";
[PTBR+18] = -1;
[PTBR+19] = "0000";



//setting the process table of idle
[PROCESS_TABLE + 11] = 74;
[PROCESS_TABLE + 1] = 0;
[PROCESS_TABLE + 4] = RUNNING;
[PROCESS_TABLE + 13] = 8*512;
[PROCESS_TABLE + 12] = 0;
[PROCESS_TABLE + 14] = PAGE_TABLE_BASE;
[PROCESS_TABLE + 15] = 10;

//setting top of stack as entry point from header
[71 * 512] = [72*512 + 1];


SP = 8 * 512;

[SYSTEM_STATUS_TABLE + 1] = 0;


ireturn;