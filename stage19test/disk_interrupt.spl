
[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 13] = SP;
SP = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 11] * 512 - 1;
backup;

[DISK_STATUS_TABLE] = 0; //freeing disk

alias q R0;
q = 0;
while (q < 16) do
    if ([PROCESS_TABLE + q * 16 + 4] == WAIT_DISK)then
        [PROCESS_TABLE + q * 16 + 4] = READY;
    endif;
    q = q + 1;
endwhile;

restore;
SP = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 13];
ireturn;