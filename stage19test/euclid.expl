decl
    int gcd(int a, int b);
enddecl

int gcd(int a, int b){    
    decl
        int out;
    enddecl
    begin
        if (a == 0) then
            out = b;
        else
            out = gcd(b % a, a);
        endif;        
        return out;
    end
}

int main() {
    decl
        int a, b, ret;
    enddecl
    begin 
        read(a);
        read(b);

        ret = gcd(a, b);
        write(ret);

        return 0;
    end
    
}