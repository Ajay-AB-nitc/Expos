// getting currentPID
alias currentPID R0;
currentPID = [SYSTEM_STATUS_TABLE + 1];

//setting current process to terminated
[PROCESS_TABLE + currentPID * 16 + 4] = TERMINATED;

alias iter R1;
iter = 1;
while (iter < 16) do
    if ([PROCESS_TABLE + iter * 16 + 4] != TERMINATED) then
        call MOD_5;
    endif;
    iter = iter + 1;
endwhile;

halt;
